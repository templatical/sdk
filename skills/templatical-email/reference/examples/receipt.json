      "columns": "1",
      "children": [
        [
          {
            "id": "btn_order",
            "type": "button",
            "styles": {
              "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
            },
            "text": "View your order",
            "url": "https://example.com/orders/10432",
            "backgroundColor": "#1d4ed8",
            "textColor": "#ffffff",
            "borderRadius": 6,
            "fontSize": 15,
            "buttonPadding": {
              "top": 12,
              "right": 24,
              "bottom": 12,
              "left": 24
            }
          }
        ]
      ]
