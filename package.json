{
  "name": "templatical",
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "liquidjs": "^10.25.7",
    "vue": "^3.5.33",
    "vue-advanced-cropper": "^2.8.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@templatical/editor": "workspace:*",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-font-family": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/reactivity": "^3.5.33",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "syncpack": "^14.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vue-eslint-parser": "^10.4.0"
  },
  "private": true,
  "scripts": {
    "build": "bun run --filter '@templatical/media-library' build:all && bun run --filter '@templatical/types' build && bun run --filter '@templatical/core' --filter '@templatical/renderer' --filter '@templatical/import-beefree' build && bun run --filter '@templatical/editor' build:all",
    "build:all-sdk": "bun run build:email-editor && bun run build:media-library",
    "build:email-editor": "bun run --filter '@templatical/editor' build:cdn",
    "build:media-library": "bun run --filter '@templatical/media-library' build:cdn",
    "ci": "bun run format && bun run lint && bun run typecheck && bun run test",
    "deps:check": "syncpack lint && syncpack format --check",
    "deps:fix": "syncpack fix && syncpack format",
    "deps:update": "syncpack update",
    "format": "prettier --write 'packages/*/src/**/*.{ts,vue}' 'apps/*/src/**/*.{ts,vue}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,vue}' 'apps/*/src/**/*.{ts,vue}'",
    "lint": "eslint packages/*/src apps/*/src",
    "prepare": "husky",
    "test": "bun run --filter './packages/*' test",
    "test:coverage": "bun run --filter './packages/*' test -- --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter '@templatical/playground' typecheck"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
