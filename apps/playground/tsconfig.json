{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@templatical/types": ["../../packages/types/src/index.ts"],
      "@templatical/core": ["../../packages/core/src/index.ts"],
      "@templatical/core/cloud": ["../../packages/core/src/cloud/index.ts"],
      "@templatical/media-library": ["../../packages/media-library/src/index.ts"],
      "@templatical/editor": ["../../packages/editor/src/index.ts"],
      "@templatical/renderer": ["../../packages/renderer/src/index.ts"],
      "@templatical/import-beefree": ["../../packages/import-beefree/src/index.ts"],
      "@templatical/import-unlayer": ["../../packages/import-unlayer/src/index.ts"],
      "@templatical/import-html": ["../../packages/import-html/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/env.d.ts"]
}
