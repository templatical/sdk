{
  "name": "@templatical/editor",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Vue 3 visual drag-and-drop email editor powered by Templatical",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/templatical-editor.umd.cjs",
  "module": "./dist/templatical-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/templatical-editor.js",
      "require": "./dist/templatical-editor.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:cdn": "vite build --config vite.cdn.config.ts",
    "build:all": "vite build && vite build --config vite.cdn.config.ts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@templatical/core": "workspace:*",
    "@templatical/types": "workspace:*",
    "@tiptap/core": "^3.22.0",
    "@tiptap/extension-color": "^3.22.0",
    "@tiptap/extension-font-family": "^3.22.0",
    "@tiptap/extension-highlight": "^3.22.0",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-subscript": "^3.22.0",
    "@tiptap/extension-superscript": "^3.22.0",
    "@tiptap/extension-text-align": "^3.22.0",
    "@tiptap/extension-text-style": "^3.22.0",
    "@tiptap/extension-underline": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@tiptap/vue-3": "^3.22.0",
    "@vueuse/core": "^14.0.0",
    "liquidjs": "^10.0.0",
    "@lucide/vue": "^1.0.0",
    "vanilla-colorful": "^0.7.2",
    "vuedraggable": "^4.1.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "@templatical/renderer": "^0.0.4",
    "@templatical/media-library": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@templatical/renderer": {
      "optional": true
    },
    "@templatical/media-library": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  }
}
