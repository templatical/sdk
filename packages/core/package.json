{
  "name": "@templatical/core",
  "description": "Framework-agnostic editor logic for Templatical email editor",
  "version": "0.16.3",
  "bugs": "https://github.com/templatical/sdk/issues",
  "dependencies": {
    "@templatical/types": "workspace:*",
    "@vue/reactivity": "^3.5.40"
  },
  "devDependencies": {
    "pusher-js": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.40"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cloud": {
      "types": "./dist/cloud/index.d.ts",
      "import": "./dist/cloud/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://templatical.com",
  "keywords": [
    "editor-core",
    "email",
    "email-editor",
    "framework-agnostic",
    "templatical",
    "vue-reactivity"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "module": "./dist/index.js",
  "peerDependencies": {
    "pusher-js": "^8.5.0"
  },
  "peerDependenciesMeta": {
    "pusher-js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/templatical/sdk.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
