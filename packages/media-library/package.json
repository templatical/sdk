{
  "name": "@templatical/media-library",
  "description": "Media library management for Templatical email editor",
  "version": "0.2.0",
  "bugs": "https://github.com/templatical/sdk/issues",
  "dependencies": {
    "@lucide/vue": "^1.11.0",
    "@templatical/core": "workspace:*",
    "@templatical/types": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "vue-advanced-cropper": "^2.8.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/templatical-media-library.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://templatical.com",
  "keywords": [
    "asset-manager",
    "image-upload",
    "media-library",
    "media-manager",
    "templatical",
    "vue"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "module": "./dist/templatical-media-library.js",
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/templatical/sdk.git",
    "directory": "packages/media-library"
  },
  "scripts": {
    "build": "vite build",
    "build:all": "vite build && vite build --config vite.cdn.config.ts",
    "build:cdn": "vite build --config vite.cdn.config.ts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
