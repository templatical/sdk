{
  "name": "@templatical/media-library",
  "version": "0.0.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Media library management for Templatical email editor",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/templatical-media-library.umd.cjs",
  "module": "./dist/templatical-media-library.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/templatical-media-library.js",
      "require": "./dist/templatical-media-library.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:cdn": "vite build --config vite.cdn.config.ts",
    "build:all": "vite build && vite build --config vite.cdn.config.ts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@templatical/core": "workspace:*",
    "@templatical/types": "workspace:*",
    "@vueuse/core": "^14.0.0",
    "@lucide/vue": "^1.0.0",
    "vue-advanced-cropper": "^2.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  }
}
