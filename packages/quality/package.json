{
  "name": "@templatical/quality",
  "description": "Accessibility linter for Templatical email templates",
  "version": "0.11.1",
  "bugs": "https://github.com/templatical/sdk/issues",
  "dependencies": {
    "@templatical/types": "workspace:*",
    "htmlparser2": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://templatical.com",
  "keywords": [
    "a11y",
    "accessibility",
    "email",
    "linter",
    "templatical",
    "wcag"
  ],
  "license": "MIT",
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/templatical/sdk.git",
    "directory": "packages/quality"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && api-extractor run --local && rm -rf dist/types",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
